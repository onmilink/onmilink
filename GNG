<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>GNG SS26 — Dashboard Captación de Leads</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=DM+Sans:wght@300;400;500&display=swap');

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --black: #0e0e0e;
    --white: #f5f3ef;
    --cream: #ede9e2;
    --mid: #c8c4bc;
    --muted: #8a8780;
    --accent: #b8a48a;
    --green: #3a6b2a;
    --green-bg: #e8f0e4;
    --red: #8b2c2c;
    --red-bg: #f5e4e4;
    --blue: #1e3a5f;
    --blue-bg: #e0e9f5;
    --border: rgba(0,0,0,0.1);
  }

  body {
    background: var(--white);
    color: var(--black);
    font-family: 'DM Sans', sans-serif;
    font-size: 13px;
    line-height: 1.5;
    min-height: 100vh;
    padding: 0;
  }

  /* HEADER */
  .header {
    background: var(--black);
    color: var(--white);
    padding: 20px 40px;
    display: flex;
    align-items: center;
    gap: 24px;
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }
  .header-logo svg path { fill: var(--white); }
  .header-logo { display: flex; align-items: center; }
  .header-divider { width: 1px; height: 32px; background: rgba(255,255,255,0.15); }
  .header-meta { flex: 1; }
  .header-title { font-size: 16px; font-weight: 500; letter-spacing: 0.02em; }
  .header-sub { font-size: 11px; color: rgba(255,255,255,0.45); margin-top: 2px; font-family: 'DM Mono', monospace; }
  .header-badge {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    padding: 4px 10px;
    border: 1px solid rgba(255,255,255,0.2);
    border-radius: 2px;
    color: rgba(255,255,255,0.6);
    letter-spacing: 0.08em;
  }

  /* LAYOUT */
  .main { padding: 32px 40px; max-width: 1200px; margin: 0 auto; }

  .section-label {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.12em;
    color: var(--muted);
    text-transform: uppercase;
    margin-bottom: 14px;
    padding-bottom: 6px;
    border-bottom: 1px solid var(--border);
  }

  /* KPI STRIP */
  .kpi-strip {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    border: 1px solid var(--border);
    border-radius: 4px;
    overflow: hidden;
    margin-bottom: 32px;
    background: var(--cream);
  }
  .kpi-cell {
    padding: 18px 22px;
    border-right: 1px solid var(--border);
  }
  .kpi-cell:last-child { border-right: none; }
  .kpi-label {
    font-family: 'DM Mono', monospace;
    font-size: 9px;
    color: var(--muted);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 6px;
  }
  .kpi-val {
    font-size: 26px;
    font-weight: 300;
    color: var(--black);
    line-height: 1;
    letter-spacing: -0.02em;
  }
  .kpi-sub {
    font-size: 10px;
    color: var(--muted);
    margin-top: 4px;
    font-family: 'DM Mono', monospace;
  }

  /* CAMPAIGNS */
  .camp-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    margin-bottom: 36px;
  }
  .camp-card {
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 18px 20px;
    background: var(--cream);
  }
  .camp-card.germany {
    border-color: #1e3a5f;
    border-left: 3px solid #1e3a5f;
    background: #f0f4fa;
  }
  .camp-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 12px;
  }
  .camp-name {
    font-family: 'DM Mono', monospace;
    font-size: 9px;
    color: var(--muted);
    letter-spacing: 0.04em;
    line-height: 1.5;
    max-width: 320px;
  }
  .camp-pill {
    font-family: 'DM Mono', monospace;
    font-size: 9px;
    padding: 3px 8px;
    border-radius: 2px;
    white-space: nowrap;
    font-weight: 500;
  }
  .pill-de { background: var(--blue-bg); color: var(--blue); }
  .pill-es { background: var(--green-bg); color: var(--green); }
  .pill-test { background: #fff3e0; color: #7a4a00; margin-right: 6px; }
  .camp-metrics-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 8px;
  }
  .cm { }
  .cm-label { font-size: 9px; color: var(--muted); font-family: 'DM Mono', monospace; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 3px; }
  .cm-val { font-size: 17px; font-weight: 500; color: var(--black); }
  .cm-val.highlight { color: var(--blue); }

  /* ADS SECTION */
  .ads-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 12px;
    margin-bottom: 36px;
  }
  .ad-card {
    border: 1px solid var(--border);
    border-radius: 4px;
    overflow: hidden;
    background: #fff;
    display: flex;
    flex-direction: column;
    transition: box-shadow 0.2s;
    cursor: default;
  }
  .ad-card:hover { box-shadow: 0 4px 20px rgba(0,0,0,0.08); }
  .ad-img-wrap {
    width: 100%;
    aspect-ratio: 3/4;
    overflow: hidden;
    background: var(--cream);
    position: relative;
  }
  .ad-img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: grayscale(8%);
  }
  .ad-rank {
    position: absolute;
    top: 8px;
    left: 8px;
    background: var(--black);
    color: var(--white);
    font-family: 'DM Mono', monospace;
    font-size: 9px;
    padding: 3px 7px;
    border-radius: 2px;
    letter-spacing: 0.06em;
  }
  .ad-status-dot {
    position: absolute;
    top: 8px;
    right: 8px;
    width: 7px; height: 7px;
    border-radius: 50%;
  }
  .dot-active { background: #3a6b2a; }
  .dot-paused { background: #8a8780; }
  .dot-processing { background: #c17a00; }
  .ad-body { padding: 12px; flex: 1; display: flex; flex-direction: column; gap: 8px; }
  .ad-name { font-family: 'DM Mono', monospace; font-size: 11px; font-weight: 500; color: var(--black); }
  .ad-creative-tag { font-size: 10px; color: var(--muted); line-height: 1.3; }
  .ad-divider { height: 1px; background: var(--border); }
  .ad-stats { display: flex; flex-direction: column; gap: 5px; }
  .ad-stat-row { display: flex; justify-content: space-between; align-items: baseline; }
  .ad-stat-label { font-family: 'DM Mono', monospace; font-size: 9px; color: var(--muted); text-transform: uppercase; letter-spacing: 0.08em; }
  .ad-stat-val { font-size: 14px; font-weight: 500; color: var(--black); }
  .ad-stat-val.best { color: var(--green); }
  .ad-stat-val.worst { color: var(--red); }
  .ad-bar-wrap { height: 2px; background: var(--cream); border-radius: 1px; overflow: hidden; }
  .ad-bar { height: 100%; border-radius: 1px; background: var(--black); opacity: 0.25; }
  .ad-pct-row { display: flex; justify-content: space-between; align-items: center; }
  .ad-pct-label { font-size: 9px; color: var(--muted); font-family: 'DM Mono', monospace; }
  .ad-pct-val { font-size: 9px; color: var(--muted); font-family: 'DM Mono', monospace; }

  /* FOOTER */
  .footer {
    margin-top: 24px;
    padding-top: 16px;
    border-top: 1px solid var(--border);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .footer-note { font-family: 'DM Mono', monospace; font-size: 9px; color: var(--muted); letter-spacing: 0.06em; }
</style>
</head>
